# Copy this file to `.streamlit/secrets.toml` for LOCAL runs (that real file is
# gitignored — never commit secrets). On Streamlit Community Cloud, paste the
# same key=value lines into the app's Settings -> Secrets box instead.

# --- OpenRouter (cheap / free models) ---
OPENROUTER_API_KEY = "sk-or-your-key-here"

# Optional: pick a model (any ':free' id works). If omitted, a free default is used.
INSIGHT_COPILOT_MODEL = "meta-llama/llama-3.3-70b-instruct:free"

# --- OR Anthropic (Claude) instead ---
# ANTHROPIC_API_KEY = "sk-ant-your-key-here"

# Optional: force a provider ("openrouter", "anthropic", or "heuristic").
# INSIGHT_COPILOT_PROVIDER = "openrouter"
